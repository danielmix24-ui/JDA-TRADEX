    window.validarAccesoGlobal = function(event) {
      event.preventDefault();
      const userIn = document.getElementById("username").value.trim().toLowerCase();
      const passIn = document.getElementById("password").value;
      let autenticado = false;
      let nombre = "";
      let rol = "";

      if ((userIn === "admin" && passIn === "jdaseguro2026") || (userIn === "daniel" && passIn === "tradex2026")) {
        autenticado = true;
        nombre = "Daniel (Admin)";
        rol = "Administrador";
      } else if (userIn === "vendedor" && passIn === "tradex01") {
        autenticado = true;
        nombre = "Operador Ventas";
        rol = "Vendedor";
      }

      if (autenticado) {
        localStorage.setItem("tradex_sesion_activa", nombre);
        localStorage.setItem("tradex_rol_activo", rol);
        document.getElementById("login-container").style.display = "none";
        document.getElementById("app-container").style.display = "block";
        inicializarModulosSegunRol(rol);
      } else {
        document.getElementById("error-msg").style.display = "block";
      }
    };

    function inicializarModulosSegunRol(rolActivo) {
      document.getElementById("session-role-badge").innerText = rolActivo.toUpperCase();
      const navFinanzas = document.getElementById("nav-section-admin-finanzas");
      const navConfig = document.getElementById("nav-section-admin-config");
      const btnVerGananciaVend = document.getElementById("btn-ver-ganancia-vendedor");
      const btnVerGananciaAdmin = document.getElementById("btn-ver-ganancia-admin");
      const mCaja = document.getElementById("m-nav-caja");
      const mTrigger = document.getElementById("m-nav-admin-trigger");
      const campoTasa = document.getElementById('rm-tasa');
      const campoGananciaVendedorManual = document.getElementById('rm-ganancia-vendedor-manual');
      const thAcciones = document.getElementById('th-acciones-admin');
      const thAccionesClienteAdmin = document.querySelectorAll('.th-acciones-cliente-admin');

      // Remover cualquier Nav Item duplicado de Mis Préstamos preventivamente
      const itemViejo = document.getElementById('nav-item-mis-prestamos');
      if (itemViejo) itemViejo.remove();
      const drawerViejo = document.getElementById('drawer-item-mis-prestamos');
      if (drawerViejo) drawerViejo.remove();

      if (rolActivo === "Vendedor") {
        if(navFinanzas) navFinanzas.style.display = "none";
        if(navConfig) navConfig.style.display = "none";
        if(mCaja) mCaja.style.display = "none";
        if(btnVerGananciaAdmin) btnVerGananciaAdmin.style.display = "none";
        if(mTrigger) mTrigger.style.display = "none";
        if(btnVerGananciaVend) btnVerGananciaVend.style.display = "inline-flex";
        if(campoTasa) { campoTasa.readOnly = true; campoTasa.classList.add('bloqueado-vendedor'); }
        if(campoGananciaVendedorManual) { campoGananciaVendedorManual.readOnly = true; campoGananciaVendedorManual.classList.add('bloqueado-vendedor'); }
        if(thAcciones) thAcciones.style.display = "none";
        thAccionesClienteAdmin.forEach(el => el.style.display = "none");
      } else {
        if(navFinanzas) navFinanzas.style.display = "block";
        if(navConfig) navConfig.style.display = "block";
        if(mCaja) mCaja.style.display = "flex";
        if(btnVerGananciaVend) btnVerGananciaVend.style.display = "inline-flex";
        if(btnVerGananciaAdmin) btnVerGananciaAdmin.style.display = "inline-flex";
        if(mTrigger) mTrigger.style.display = "flex";
        if(campoTasa) { campoTasa.readOnly = false; campoTasa.classList.remove('bloqueado-vendedor'); }
        if(campoGananciaVendedorManual) { campoGananciaVendedorManual.readOnly = false; campoGananciaVendedorManual.classList.remove('bloqueado-vendedor'); }
        if(thAcciones) thAcciones.style.display = "table-cell";
        thAccionesClienteAdmin.forEach(el => el.style.display = "table-cell");

        // Insertar menú MIS PRÉSTAMOS en la barra lateral para el Administrador
        const divPrincipal = document.querySelector('.nav-section');
        if (divPrincipal) {
          const mPrestamosItem = document.createElement('div');
          mPrestamosItem.className = "nav-item";
          mPrestamosItem.id = "nav-item-mis-prestamos";
          mPrestamosItem.onclick = () => window.goto('misprestamos', mPrestamosItem);
          mPrestamosItem.innerHTML = `<span class="icon">💳</span><span>Mis Préstamos</span>`;
          divPrincipal.appendChild(mPrestamosItem);
        }

        // Insertar en el Drawer Móvil de Administración
        const drawerAdmin = document.getElementById('mobile-admin-drawer');
        if (drawerAdmin) {
          const drawerItem = document.createElement('div');
          drawerItem.className = "drawer-item";
          drawerItem.id = "drawer-item-mis-prestamos";
          drawerItem.onclick = () => window.gotoMobile('misprestamos');
          drawerItem.innerText = "💳 Mis Préstamos";
          drawerAdmin.appendChild(drawerItem);
        }
      }
      renderizarTablaRemesas();
      renderizarTablaClientes();
      renderizarTablaRecargas();
      calcularGananciasDelDia();
    }

