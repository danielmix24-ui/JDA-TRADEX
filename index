    const app = initializeApp(firebaseConfig);
    const db = getDatabase(app);

    let variablesGlobales = { usdt_ves: 46.20, ganancia_casa: 6.0, ganancia_vendedor: 0.0 };
    let listaClientes = [];
    let listaRemesas = [];
    let listaRecargas = [];
    let listaBancos = [];
    let listaPrestamos = [];
    let historialPrestamos = [];
    let historialCaja = [];
    let baseAperturaCajaGlobal = 0;
