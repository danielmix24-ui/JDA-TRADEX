    window.openModal = function(id) { document.getElementById(id).classList.add('open'); };
    window.closeModal = function(id) { document.getElementById(id).classList.remove('open'); };

    onValue(ref(db, 'tasas_globales'), (snapshot) => {
      if (snapshot.exists()) {
        variablesGlobales = snapshot.val();
        cargarInputsDesdeMemoria();
        autoCalcularEstructuraCompleta(false);
      }
    });

    onValue(ref(db, 'clientes'), (snapshot) => {
      listaClientes = [];
      if (snapshot.exists()) {
        Object.entries(snapshot.val()).forEach(([key, value]) => {
          listaClientes.push({ firebaseUrlKey: key, ...value });
        });
      }
      listaClientes.sort((a,b) => a.nombre.localeCompare(b.nombre));
      sconizarSelectoresDeClientes();
      renderizarTablaClientes();
    });

    onValue(ref(db, 'remesas'), (snapshot) => {
      listaRemesas = [];
      if (snapshot.exists()) {
        Object.entries(snapshot.val()).forEach(([key, value]) => {
          listaRemesas.push({ firebaseUrlKey: key, ...value });
        });
      }
      renderizarTablaRemesas();
      calcularGananciasDelDia();
    });

    onValue(ref(db, 'recargas'), (snapshot) => {
      listaRecargas = [];
      if (snapshot.exists()) {
        Object.entries(snapshot.val()).forEach(([key, value]) => {
          listaRecargas.push({ firebaseUrlKey: key, ...value });
        });
      }
      renderizarTablaRecargas();
    });

    onValue(ref(db, 'prestamos'), (snapshot) => {
      listaPrestamos = [];
