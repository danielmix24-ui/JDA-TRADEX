          const ahora = new Date();
          const fStr = grandmaFechaString(ahora) + " " + ahora.toLocaleTimeString('es-VE', {hour:'2-digit', minute:'2-digit'});
          const histPayload = { prestamoKey: snapshot.key, fechaHora: fStr, cliente: cli, tipoAccion: "Apertura Préstamo", montoBase: mon, interesAplicado: 0 };
          push(ref(db, 'prestamos_historial'), histPayload);
          window.closeModal('modal-prestamo');
          document.getElementById('pr-monto').value = "";
          pushNotification("💳 Apertura de préstamo procesada.");
        });
    };

    window.activarModalPagarInteres = function(key, cliente) {
      window.openModal('modal-pagar-interes');
      document.getElementById('pi-fecha-abono').value = new Date().toISOString().split('T')[0];
      document.getElementById('btn-confirmar-pago-interes').onclick = () => {
        const mpi = parseFloat(document.getElementById('pi-monto').value) || 0;
        const fechaAbonoRaw = document.getElementById('pi-fecha-abono').value;
        if(mpi <= 0 || !fechaAbonoRaw) { alert("Ingrese datos de interés consistentes."); return; }
        
        let partesFecha = fechaAbonoRaw.split('-');
        let fechaFormateada = `${partesFecha[2]}/${partesFecha[1]}/${partesFecha[0]}`;
        const ahora = new Date();
        const horaStr = ahora.toLocaleTimeString('es-VE', {hour:'2-digit', minute:'2-digit'});

        const payloadAbono = {
          prestamoKey: key,
          fechaHora: `${fechaFormateada} ${horaStr}`,
          cliente: cliente,
          tipoAccion: "Pago Interés",
          montoBase: 0,
          interesAplicado: mpi
        };

        push(ref(db, 'prestamos_historial'), payloadAbono)
          .then(() => {
            update(ref(db, `prestamos/${key}`), { ultimoAbono: `$${mpi.toFixed(2)} (${fechaFormateada})` });
            window.closeModal('modal-pagar-interes');
            document.getElementById('pi-monto').value = "";
            pushNotification("💵 Abono de interés registrado con éxito.");
          });
      };
    };

    window.verReciboPrestamo = function(p) {
      const cont = document.getElementById('detalle-orden-contenido');
      let fEntregaParts = p.fechaEntrega ? p.fechaEntrega.split('-') : [];
      let fEntregaFormateada = fEntregaParts.length === 3 ? `${fEntregaParts[2]}/${fEntregaParts[1]}/${fEntregaParts[0]}` : p.fechaEntrega || 'N/A';
      let fVencParts = p.vencimiento ? p.vencimiento.split('-') : [];
      let fVencFormateada = fVencParts.length === 3 ? `${fVencParts[2]}/${fVencParts[1]}/${fVencParts[0]}` : p.vencimiento || 'N/A';

      let historialAbonosTexto = "";
      let abonosFiltrados = historialPrestamos.filter(h => h.prestamoKey === p.firebaseUrlKey && h.tipoAccion === "Pago Interés");
      if(abonosFiltrados.length > 0) {
        abonosFiltrados.forEach(a => {
          historialAbonosTexto += `FECHA: ${a.fechaHora.split(' ')[0]} - MONTO: $${a.interesAplicado.toFixed(2)}\n`;
        });
      } else {
        historialAbonosTexto = "SIN ABONOS REGISTRADOS\n";
      }

      cont.innerHTML = `<pre style="font-family:monospace; font-size:12px; color:var(--text); white-space:pre-wrap;">
========================================
 RECEPCIÓN DE PRÉSTAMO JDA TRADEX
========================================
CLIENTE DEUDOR: ${p.cliente}
CAPITAL ENTREGADO: $${p.monto.toFixed(2)} USD
TASA DE INTERÉS: ${p.interesPct}%
ESTADO ACTUAL: ${p.estado.toUpperCase()}
----------------------------------------
FECHA DE ENTREGA: ${fEntregaFormateada}
FECHA DE VENCIMIENTO: ${fVencFormateada}
----------------------------------------
HISTORIAL PAGO DE INTERESES
----------------------------------------
${historialAbonosTexto}========================================
 ¡Gracias por su confianza!
========================================</pre>`;

      document.getElementById('btn-compartir-whatsapp').onclick = () => {
        const rawText = `*RECEPCIÓN DE PRÉSTAMO JDA TRADEX*\n\n👤 *Cliente:* ${p.cliente}\n💵 *Capital:* $${p.monto.toFixed(2)} USD\n📈 *Interés:* ${p.interesPct}%\n📅 *Entrega:* ${fEntregaFormateada}\n📅 *Vencimiento:* ${fVencFormateada}\n⚡ *Estado:* ${p.estado.toUpperCase()}`;
        window.open(`https://api.whatsapp.com/send?text=${encodeURIComponent(rawText)}`, '_blank');
      };

      document.getElementById('btn-compartir-externo').onclick = () => {
        const txt = `RECEPCIÓN DE PRÉSTAMO JDA TRADEX\n\nCliente: ${p.cliente}\nCapital: $${p.monto.toFixed(2)} USD\nInterés: ${p.interesPct}%\nEntrega: ${fEntregaFormateada}\nVencimiento: ${fVencFormateada}`;
        if(navigator.clipboard) navigator.clipboard.writeText(txt).then(() => alert("Copiado al portapapeles."));
      };

      window.openModal('modal-ver-orden');
    };

    window.verTransaccionesPrestamo = function(key) {
      let tFiltradas = historialPrestamos.filter(h => h.prestamoKey === key);
      let tTexto = tFiltradas.map(t => `[${t.fechaHora}] ${t.tipoAccion}: ${t.montoBase > 0 ? '$'+t.montoBase : '$'+t.interesAplicado}`).join('\n');
      alert(tTexto || "No hay transacciones registradas.");
    };

    window.liquidarPrestamoTotal = function(key, cliente, monto) {
      if(confirm(`¿Confirmar que el préstamo de $${monto} de ${cliente} ha sido pagado por completo?`)) {
        const ahora = new Date();
        const fLiqui = grandmaFechaString(ahora) + " " + ahora.toLocaleTimeString('es-VE', {hour:'2-digit', minute:'2-digit'});
        update(ref(db, `prestamos/${key}`), { estado: "Liquidado", fechaLiquidado: fLiqui })
          .then(() => {
            const histPayload = { prestamoKey: key, fechaHora: fLiqui, cliente: cliente, tipoAccion: "Liquidación Préstamo", montoBase: monto, interesAplicado: 0 };
            push(ref(db, 'prestamos_historial'), histPayload);
            pushNotification("✨ Préstamo liquidado correctamente.");
          });
      }
    };

    window.eliminarPrestamoDefinitivo = function(key) {
      if(confirm("¿Eliminar este préstamo y todo su historial de la base de datos?")) {
        remove(ref(db, `prestamos/${key}`)).then(() => {
          historialPrestamos.filter(h => h.prestamoKey === key).forEach(h => {
            remove(ref(db, `prestamos_historial/${h.firebaseUrlKey}`));
          });
          pushNotification("🗑️ Préstamo removido por completo.");
        });
      }
    };

    function renderizarTablaPréstamos() {
      // Sincronizar simultáneamente ambas vistas de Préstamos (Nativa y Mis Préstamos)
      const tbodies = [
        { active: 'prestamos-tbody', settled: 'prestamos-liquidados-tbody' },
        { active: 'misprestamos-tbody', settled: 'misprestamos-liquidados-tbody' }
      ];

      tbodies.forEach(setIds => {
        const tbodyActivos = document.getElementById(setIds.active);
        const tbodyLiquidados = document.getElementById(setIds.settled);
        if(!tbodyActivos || !tbodyLiquidados) return;

        tbodyActivos.innerHTML = "";
        tbodyLiquidados.innerHTML = "";

        listaPrestamos.forEach(p => {
          let tr = document.createElement('tr');
          if (p.estado === "Activo") {
            tr.innerHTML = `
              <td><strong>${p.cliente}</strong></td>
              <td>$${p.monto.toFixed(2)}</td>
              <td>${p.interesPct}%</td>
              <td><small>${p.ultimoAbono || 'Ninguno'}</small></td>
              <td>${p.vencimiento}</td>
              <td><span class="badge badge-pendiente">Activo</span></td>
              <td>
                <button class="btn btn-success btn-sm btn-pag-int">💸 Abonar Int</button>
                <button class="btn btn-teal btn-sm btn-ver-recib">Recibo</button>
                <button class="btn btn-purple btn-sm btn-ver-trx">Historial</button>
                <button class="btn btn-p btn-sm btn-liquidar">✓ Liquidar</button>
                <button class="btn btn-danger btn-sm btn-eliminar">✕ Borrar</button>
              </td>
            `;
            tr.querySelector('.btn-pag-int').onclick = () => window.activarModalPagarInteres(p.firebaseUrlKey, p.cliente);
            tr.querySelector('.btn-ver-recib').onclick = () => window.verReciboPrestamo(p);
            tr.querySelector('.btn-ver-trx').onclick = () => window.verTransaccionesPrestamo(p.firebaseUrlKey);
            tr.querySelector('.btn-liquidar').onclick = () => window.liquidarPrestamoTotal(p.firebaseUrlKey, p.cliente, p.monto);
            tr.querySelector('.btn-eliminar').onclick = () => window.eliminarPrestamoDefinitivo(p.firebaseUrlKey);
            tbodyActivos.appendChild(tr);
          } else {
            tr.innerHTML = `
              <td><strong>${p.cliente}</strong></td>
              <td>$${p.monto.toFixed(2)}</td>
              <td>${p.interesPct}%</td>
              <td>${p.vencimiento}</td>
              <td><small>${p.fechaLiquidado || 'N/A'}</small></td>
              <td><span class="badge badge-procesada">Liquidado</span></td>
              <td>
                <button class="btn btn-teal btn-sm btn-ver-recib">Recibo</button>
                <button class="btn btn-danger btn-sm btn-eliminar">Borrar</button>
              </td>
            `;
            tr.querySelector('.btn-ver-recib').onclick = () => window.verReciboPrestamo(p);
            tr.querySelector('.btn-eliminar').onclick = () => window.eliminarPrestamoDefinitivo(p.firebaseUrlKey);
            tbodyLiquidados.appendChild(tr);
          }
        });
      });
    }

    function renderizarTablaHistorialPrestamos() {
      const targets = ['prestamos-historial-tbody', 'misprestamos-historial-tbody'];
      targets.forEach(id => {
        const tbody = document.getElementById(id);
        if(!tbody) return;
        tbody.innerHTML = "";
        historialPrestamos.forEach(h => {
          let tr = document.createElement('tr');
          tr.innerHTML = `
            <td>${h.fechaHora}</td>
            <td><strong>${h.cliente}</strong></td>
            <td><span class="badge badge-pendiente">${h.tipoAccion}</span></td>
            <td>$${h.montoBase.toFixed(2)}</td>
            <td style="color:var(--success); font-weight:bold;">$${h.interesAplicated ? h.interesAplicated.toFixed(2) : (h.interesApplicado || h.interesAplicado || 0).toFixed(2)}</td>
            <td><button class="btn btn-danger btn-sm">Borrar</button></td>
          `;
          tr.querySelector('.btn-danger').onclick = () => window.eliminarTransaccionHistorial(h.firebaseUrlKey);
          tbody.appendChild(tr);
        });
      });
      calcularGananciasInteresesTotales();
    }

    window.eliminarTransaccionHistorial = function(key) {
      if(confirm("¿Remover esta transacción del historial permanente?")) {
        remove(ref(db, `prestamos_historial/${key}`)).then(() => pushNotification("🗑️ Elemento extraído."));
      }
    };

    function calcularGananciasInteresesTotales() {
      let suma = 0;
      historialPrestamos.forEach(h => {
        if(h.tipoAccion === "Pago Interés") {
          suma += parseFloat(h.interesAplicated || h.interesApplicado || h.interesAplicado || 0);
        }
      });
      
      const targets = ['prestamos-ganancias-intereses', 'misprestamos-ganancias-intereses'];
      targets.forEach(id => {
        const el = document.getElementById(id);
        if(el) el.innerText = suma.toFixed(2) + " USD";
      });
      
      let totalEntregado = 0;
      listaPrestamos.forEach(p => totalEntregado += p.monto || 0);
      
      const targetsEntregado = ['prestamos-total-entregado', 'misprestamos-total-entregado'];
      targetsEntregado.forEach(id => {
        const el = document.getElementById(id);
        if(el) el.innerText = totalEntregado.toFixed(2) + " USD";
      });
    }

    window.registrarMovementoCaja = function() {
      const tipo = document.getElementById('cj-tipo').value;
      const monto = parseFloat(document.getElementById('cj-monto').value) || 0;
      const concepto = document.getElementById('cj-concepto').value.trim();

      if(monto <= 0 || !concepto) { alert("Complete los montos y conceptos de caja."); return; }
      const ahora = new Date();
      const hStr = ahora.toLocaleTimeString('es-VE', {hour:'2-digit', minute:'2-digit'});

      const payload = { hora: hStr, tipo: tipo, concepto: concepto, monto: monto };
      push(ref(db, 'caja_diaria'), payload)
        .then(() => {
          document.getElementById('cj-monto').value = "";
          document.getElementById('cj-concepto').value = "";
          pushNotification("🗄️ Caja sincronizada en tiempo real.");
        });
    };

    function renderizarTablaCaja() {
      const tbody = document.getElementById('caja-tbody');
      if(!tbody) return;
      tbody.innerHTML = "";
      historialCaja.forEach(c => {
        let tr = document.createElement('tr');
        let col = c.tipo === "Ingreso" ? "var(--success)" : "var(--danger)";
        tr.innerHTML = `<td>${c.hora}</td><td style="color:${col}; font-weight:bold;">${c.tipo}</td><td>${c.concepto}</td><td style="color:${col}; font-weight:bold;">Bs. ${c.monto.toFixed(2)}</td>`;
        tbody.appendChild(tr);
      });
      calcularFlujoCajaTotal();
    }

    window.guardarBaseAperturaCaja = function() {
      const val = parseFloat(document.getElementById('cj-apertura').value) || 0;
      set(ref(db, 'caja_apertura_base'), val);
    };

    function calcularFlujoCajaTotal() {
      let ingresos = 0; let egresos = 0;
      historialCaja.forEach(c => {
        if(c.tipo === "Ingreso") ingresos += c.monto;
        else egresos += c.monto;
      });
      let disponible = baseAperturaCajaGlobal + ingresos - egresos;
      if(document.getElementById('total-ingresos-box')) document.getElementById('total-ingresos-box').innerText = "Bs. " + ingresos.toFixed(2);
      if(document.getElementById('total-egresos-box')) document.getElementById('total-egresos-box').innerText = "Bs. " + egresos.toFixed(2);
      if(document.getElementById('saldo-caja-box')) document.getElementById('saldo-caja-box').innerText = "Bs. " + disponible.toFixed(2);
    }

    window.registrarBanco = function() {
      const plat = document.getElementById('bn-plataforma').value.trim();
      const iden = document.getElementById('bn-identificador').value.trim();
      const sald = parseFloat(document.getElementById('bn-saldo').value) || 0;

      if(!plat || !iden) { alert("Coloque datos válidos para la cuenta."); return; }
      const payload = { plataforma: plat, identificador: iden, saldo: sald };
      push(ref(db, 'bancos'), payload)
        .then(() => {
          document.getElementById('bn-plataforma').value = "";
          document.getElementById('bn-identificador').value = "";
          document.getElementById('bn-saldo').value = "";
          pushNotification("🏦 Banco sincronizado con éxito.");
        });
    };

    window.eliminarBanco = function(key) {
      if(confirm("¿Remover esta plataforma bancaria?")) {
        remove(ref(db, `bancos/${key}`)).then(() => pushNotification("🗑️ Banco removido de la red."));
      }
    };

    function renderizarTablaBancos() {
      const tbody = document.getElementById('bancos-tbody');
      if(!tbody) return;
      tbody.innerHTML = "";
      listaBancos.forEach(b => {
        let tr = document.createElement('tr');
        tr.innerHTML = `<td><strong>${b.plataforma}</strong></td><td><code>${b.identificador}</code></td><td style="color:var(--success); font-weight:bold;">$${b.saldo.toFixed(2)}</td><td><button class="btn btn-danger btn-sm">Remover</button></td>`;
        tr.querySelector('.btn-danger').onclick = () => window.eliminarBanco(b.firebaseUrlKey);
        tbody.appendChild(tr);
      });
    }

    function calcularGananciasDelDia() {
      let totalUSDTBrutoHoy = 0;
      let comisionVendedorHoy = 0;
      let comisionAdminHoy = 0;
      let montoVendedorAAdmin = 0;

      const hoyStr = grandmaFechaString(new Date());

      listaRemesas.forEach(r => {
        if(r.estado === "Completada") {
          let uBruto = parseFloat(r.usdtBruto) || 0;
          let uAdmin = parseFloat(r.usdtAdmin) || 0;
          let uVend = parseFloat(r.usdtVendedor) || 0;

          if (r.fecha === hoyStr) {
            totalUSDTBrutoHoy += uBruto;
            comisionVendedorHoy += uVend;
            comisionAdminHoy += uAdmin;
          }
          montoVendedorAAdmin += (uBruto - uVend);
        }
      });

      if(document.getElementById('dash-hoy-val')) {
        document.getElementById('dash-hoy-val').innerText = listaRemesas.filter(r => r.estado === "Procesando").length;
      }
      if(document.getElementById('dash-mes-val')) {
        document.getElementById('dash-mes-val').innerText = listaRemesas.filter(r => r.estado === "Completada").length;
      }
      if(document.getElementById('dash-ganancias-hoy')) {
        document.getElementById('dash-ganancias-hoy').innerText = totalUSDTBrutoHoy.toFixed(2) + " USDT";
      }
      if(document.getElementById('monto-vendedor-a-administrador')) {
        document.getElementById('monto-vendedor-a-administrador').innerText = montoVendedorAAdmin.toFixed(2) + " USDT";
      }
      if(document.getElementById('total-vendedor-modal-val')) {
        document.getElementById('total-vendedor-modal-val').innerText = comisionVendedorHoy.toFixed(2) + " USDT";
      }
      if(document.getElementById('total-admin-modal-val')) {
        document.getElementById('total-admin-modal-val').innerText = comisionAdminHoy.toFixed(2) + " USDT";
      }
      if(document.getElementById('dash-usdt-static')) {
        document.getElementById('dash-usdt-static').innerText = "Bs. " + (variablesGlobales.usdt_ves || 46.20).toFixed(2);
      }
    }

    function pushNotification(texto) {
      const container = document.getElementById('notification-container');
      if(!container) return;
      const toast = document.createElement('div');
      toast.className = 'toast-notification';
      toast.innerText = texto;
      container.appendChild(toast);
      setTimeout(() => { toast.remove(); }, 3500);
    }

    // Mantener la persistencia de sesión activa al refrescar
    const rolActivoEnMemoria = localStorage.getItem("tradex_rol_activo");
    const sesionActivaEnMemoria = localStorage.getItem("tradex_sesion_activa");
    if (rolActivoEnMemoria && sesionActivaEnMemoria) {
      document.getElementById("login-container").style.display = "none";
      document.getElementById("app-container").style.display = "block";
      inicializarModulosSegunRol(rolActivoEnMemoria);
    }
  </script>
</body>
</html>
