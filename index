    function calcRemesa() {
      const monto = parseFloat(document.getElementById('rm-monto').value) || 0;
      const tasa = parseFloat(document.getElementById('rm-tasa').value) || 1;
      const gananciaVendedorManual = parseFloat(document.getElementById('rm-ganancia-vendedor-manual').value) || 0;
      
      let neto = monto * tasa;
      let usdtRef = neto / (variablesGlobales.usdt_ves || 46.20);

      const pctAdmin = variablesGlobales.ganancia_casa || 0;
      const usdtAdmin = usdtRef * (pctAdmin / 100);
      const ganVendedorUSDT = usdtRef * (gananciaVendedorManual / 100);
      const enviarAdminNeto = usdtRef - ganVendedorUSDT;

      document.getElementById('rm-usdt-ref').value = usdtRef.toFixed(2);
      document.getElementById('rm-usdt-admin').value = usdtAdmin.toFixed(2) + " USDT";
      document.getElementById('rm-enviar-admin-neto').value = enviarAdminNeto.toFixed(2) + " USDT";
      document.getElementById('rm-neto').value = neto.toFixed(2);
    }
