      renderizarTablaPréstamos();
      calcularGananciasDelDia();
      calcularGananciasInteresesTotales();
    });

    onValue(ref(db, 'prestamos_historial'), (snapshot) => {
      historialPrestamos = [];
      if(snapshot.exists()) {
        Object.entries(snapshot.val()).forEach(([key, value]) => {
          historialPrestamos.push({ firebaseUrlKey: key, ...value });
        });
        historialPrestamos.reverse();
      }
      renderizarTablaHistorialPrestamos();
    });

    onValue(ref(db, 'caja_diaria'), (snapshot) => {
      historialCaja = [];
