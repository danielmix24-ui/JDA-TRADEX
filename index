      localStorage.removeItem("tradex_sesion_activa");
      localStorage.removeItem("tradex_rol_activo");
      document.getElementById("app-container").style.display = "none";
      document.getElementById("login-container").style.display = "flex";
    };

    window.toggleAdminDrawer = function() {
      document.getElementById('mobile-admin-drawer').classList.toggle('open');
    };

    window.goto = function(pageId, element) {
      document.getElementById('mobile-admin-drawer').classList.remove('open');
      document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
      document.querySelectorAll('.mobile-nav-item').forEach(m => m.classList.remove('active'));
      
      const targetPage = document.getElementById('page-' + pageId);
      if(targetPage) targetPage.classList.add('active');
      if(element && element.classList) element.classList.add('active');
      
      const mButton = document.getElementById('m-nav-' + pageId);
      if(mButton) mButton.classList.add('active');
      else if(['prestamos','bancos','config', 'usuarios', 'misprestamos'].includes(pageId)) {
        const adminTrigger = document.getElementById('m-nav-admin-trigger');
        if(adminTrigger) adminTrigger.classList.add('active');
      }
    };

    window.gotoMobile = function(pageId) {
      const iDummy = document.createElement('div');
      window.goto(pageId, iDummy);
    };

    window.autoCalcularEstructuraCompleta = function(escribirFirebase = true) {
      const refUsdtInput = document.getElementById('calc-ref-usdt');
      if(!refUsdtInput) return;
      const refUsdt = parseFloat(refUsdtInput.value) || 46.20;
      const marginCasa = parseFloat(document.getElementById('cfg-ganancia-casa').value) || 0;
      const marginVend = parseFloat(document.getElementById('cfg-ganancia-vendedor').value) || 0;

      variablesGlobales.usdt_ves = refUsdt;
      variablesGlobales.ganancia_casa = marginCasa;
      variablesGlobales.ganancia_vendedor = marginVend;

      let f = 1 - (marginCasa / 100);
      variablesGlobales.usd_ve = refUsdt;
      variablesGlobales.usd_ve_cli = refUsdt * f;

      const i = variablesGlobales.inputs || { usa:1, br:5.4, do:58.5, co:3950, pe:3.73, cl:910, ec:1 };
      variablesGlobales.brl_ve = refUsdt / i.br;
      variablesGlobales.brl_ve_cli = variablesGlobales.brl_ve * f;
      variablesGlobales.do_ve = refUsdt / i.do;
      variablesGlobales.do_ve_cli = variablesGlobales.do_ve * f;
      variablesGlobales.co_ve = refUsdt / i.co;
      variablesGlobales.co_ve_cli = variablesGlobales.co_ve * f;
      variablesGlobales.pen_ve = refUsdt / i.pe;
      variablesGlobales.pen_ve_cli = variablesGlobales.pen_ve * f;
      variablesGlobales.clp_ve = refUsdt / i.cl;
      variablesGlobales.clp_ve_cli = variablesGlobales.clp_ve * f;
      variablesGlobales.ecd_ve = refUsdt / i.ec;
      variablesGlobales.ecd_ve_cli = variablesGlobales.ecd_ve * f;

      if (escribirFirebase) {
        set(ref(db, 'tasas_globales'), variablesGlobales);
      }
      actualizarCamposTextoInformativos();
    };

    function actualizarCamposTextoInformativos() {
      if(!document.getElementById('lbl-usa-real')) return;
      document.getElementById('lbl-usa-real').value = "Real: " + (variablesGlobales.usd_ve || 0).toFixed(4) + " Bs.";
      document.getElementById('lbl-usa-cli').value = "Cliente: " + (variablesGlobales.usd_ve_cli || 0).toFixed(4) + " Bs.";
      document.getElementById('lbl-brl-real').value = "Real: " + (variablesGlobales.brl_ve || 0).toFixed(4) + " Bs.";
